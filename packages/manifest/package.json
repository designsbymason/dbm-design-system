{
  "name": "@dbm-design-system/manifest",
  "version": "0.0.0",
  "description": "Build tool that generates the agent-readable JSON component manifest from TypeScript + JSDoc.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@dbm-design-system/eslint-config": "workspace:*",
    "@dbm-design-system/tsconfig": "workspace:*",
    "eslint": "^10.7.0",
    "tsup": "^8.5.1",
    "typescript": "7.0.2"
  }
}
