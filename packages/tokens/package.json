{
  "name": "@dbm-design-system/tokens",
  "version": "0.0.0",
  "description": "Design tokens (primitive + semantic layers) for the DBM Design System.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css/*.css": "./build/css/*.css"
  },
  "files": [
    "dist",
    "build/css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node style-dictionary.config.js && tsup"
  },
  "devDependencies": {
    "@dbm-design-system/tsconfig": "workspace:*",
    "culori": "^4.0.2",
    "style-dictionary": "^5.5.0",
    "tsup": "^8.5.1",
    "typescript": "5.9.3"
  }
}
