{
  "name": "@dbm-design-system/components",
  "version": "0.0.0",
  "description": "The DBM Design System React component library.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@dbm-design-system/icons": "workspace:*",
    "@dbm-design-system/primitives": "workspace:*",
    "@dbm-design-system/tokens": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-focus-scope": "^1.1.12",
    "@radix-ui/react-portal": "^1.1.13",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-visually-hidden": "^1.2.7"
  },
  "devDependencies": {
    "@dbm-design-system/eslint-config": "workspace:*",
    "@dbm-design-system/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/react-vite": "^10.5.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.2",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  }
}
