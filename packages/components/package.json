{
  "name": "@dbm-design-system/components",
  "version": "0.0.0",
  "description": "The DBM Design System React component library.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@dbm-design-system/icons": "workspace:*",
    "@dbm-design-system/primitives": "workspace:*",
    "@dbm-design-system/tokens": "workspace:*"
  },
  "devDependencies": {
    "@dbm-design-system/eslint-config": "workspace:*",
    "@dbm-design-system/tsconfig": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "7.0.2"
  }
}
